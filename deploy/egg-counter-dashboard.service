[Unit]
Description=Egg Counter dashboard service
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
WorkingDirectory=/opt/egg-counter
EnvironmentFile=/etc/egg-counter/egg-counter.env
ExecStart=/usr/bin/env egg-counter serve --config /opt/egg-counter/config/settings.yaml --zone /opt/egg-counter/config/zone.json --host 127.0.0.1 --port 8000
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
